QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=financial_reports
QDRANT_TIMEOUT=120
QDRANT_BATCH_SIZE=64

PDF_PARSE_BATCH_PAGES=12
DOCLING_MAX_PDF_PAGES=30
EMBEDDING_BATCH_SIZE=32

YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_LLM_BASE_URL=https://llm.api.cloud.yandex.net/v1
YANDEX_MODEL_FALLBACK=gpt://<YOUR_FOLDER_ID>/yandexgpt-lite/latest

DOCS_PATH=./docs
OCR_LANGS=ru,en
OCR_USE_GPU=true
