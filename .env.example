# Qdrant (по умолчанию для локального API без Docker — localhost:6333)
QDRANT_HOST=localhost
QDRANT_PORT=6333
# Имя коллекции; если не задано в коде используется значение по умолчанию financial_reports_10k
QDRANT_COLLECTION=financial_reports
QDRANT_TIMEOUT=120
QDRANT_BATCH_SIZE=64

PDF_PARSE_BATCH_PAGES=12
DOCLING_MAX_PDF_PAGES=30
EMBEDDING_BATCH_SIZE=32

# Yandex GPT (см. src/infrastructure/services/llm_service.py)
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
# Имя модели без префикса gpt:// (в modelUri подставится gpt://{folder}/{model})
YANDEX_MODEL=yandexgpt-lite
# URL completion API
YANDEX_LLM_URL=https://llm.api.cloud.yandex.net/foundationModels/v1/completion

DOCS_PATH=./docs
OCR_LANGS=ru,en
OCR_USE_GPU=true
